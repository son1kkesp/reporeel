# IA para generar el copy del tráiler (OpenRouter). Sin ella, el script cae al fallback determinista.
OPENROUTER_API_KEY=

# Token de GitHub para subir el rate-limit de la API (lectura de repos públicos).
GITHUB_TOKEN=

# Vercel Blob: lectura/escritura del MP4, poster, jobs y caché. Auto-inyectado al desplegar en Vercel.
BLOB_READ_WRITE_TOKEN=

# URL canónica del sitio (OG/Twitter cards + URLs absolutas). En prod: https://<tu-dominio>.
# Expuesta al cliente (NEXT_PUBLIC_). En local cae a http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# ─── Solo para el render REAL en Vercel Sandbox (createSandboxRenderAdapter) ───
# En Vercel estas se inyectan automáticamente; defínelas solo para invocar el
# Sandbox desde fuera de Vercel (CI / local). Ver REQUISITOS DE DEPLOY en el README.
# VERCEL_OIDC_TOKEN=    # auto en runtime de Vercel (vercel env pull en local)
# VERCEL_TOKEN=         # alternativa a OIDC: access token personal
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=

# Timeout del render en milisegundos (default: 280000 = 280 s).
# El cold-start del Sandbox instala Chromium + HyperFrames (~2 min); 280 s deja
# margen dentro del maxDuration=300 s de la Function. Reducir una vez haya
# snapshot de sandbox (los renders en caliente son <30 s).
RENDER_TIMEOUT_MS=
